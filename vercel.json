{
  "version": 2,
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run vercel-build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api|_next|assets|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
