{
  "version": 2,
  "outputDirectory": "dist",
  "framework": null,
  "buildCommand": "pnpm run vercel-build",
  "functions": {
    "api/index.ts": {
      "includeFiles": "api/generated/client/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api|_next|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
