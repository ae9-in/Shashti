datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  output        = "../api/_generated/client"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

model Application {
  id             Int      @id @default(autoincrement())
  fullName       String
  phone          String
  email          String
  city           String
  state          String
  pincode        String
  categories     String[]
  additionalInfo String?
  status         String   @default("PENDING") // PENDING, CONTACTED, REJECTED, APPROVED
  createdAt      DateTime @default(now())
}
