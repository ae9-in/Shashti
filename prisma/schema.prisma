datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

generator client {
  provider = "prisma-client-js"
}

model Application {
  id             Int      @id @default(autoincrement())
  fullName       String
  phone          String
  email          String
  city           String
  state          String
  pincode        String
  categories     String[]
  additionalInfo String?
  status         String   @default("PENDING") // PENDING, CONTACTED, REJECTED, APPROVED
  createdAt      DateTime @default(now())
}
